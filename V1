local function applyMovementValues()
	if not currentHumanoid or not currentHumanoid.Parent then
		return
	end

	pcall(function()
		currentHumanoid.UseJumpPower = true
	end)

	currentHumanoid.WalkSpeed = wsValue
	currentHumanoid.JumpPower = jpValue

	if layingDown then
		currentHumanoid.HipHeight = -2
	else
		if originalHipHeight ~= nil then
			currentHumanoid.HipHeight = originalHipHeight
		end
	end
end

