local function cleanupTracker(model)
	local tracker = trackers[model]
	if not tracker then
		return
	end

	if tracker.holder then
		tracker.holder:Destroy()
	end
	if tracker.highlight then
		tracker.highlight:Destroy()
	end

	trackers[model] = nil
end

local function storeHumanoidDisplay(tracker, humanoid)
	if tracker.originalDisplayDistanceType == nil then
		pcall(function()
			tracker.originalDisplayDistanceType = humanoid.DisplayDistanceType
		end)
	end
	if tracker.originalHealthDisplayType == nil then
		pcall(function()
			tracker.originalHealthDisplayType = humanoid.HealthDisplayType
		end)
	end
end

local function setHumanoidDisplayHidden(tracker, humanoid, hide)
	storeHumanoidDisplay(tracker, humanoid)

	pcall(function()
		if hide then
			humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
			humanoid.HealthDisplayType = Enum.HumanoidHealthDisplayType.AlwaysOff
		else
			if tracker.originalDisplayDistanceType ~= nil then
				humanoid.DisplayDistanceType = tracker.originalDisplayDistanceType
			end
			if tracker.originalHealthDisplayType ~= nil then
				humanoid.HealthDisplayType = tracker.originalHealthDisplayType
			end
		end
	end)
end

local function applyFaceTransparency(head, tracker, transparency)
	if not head then
		return
	end

	for _, child in ipairs(head:GetChildren()) do
		if child:IsA("Decal") or child:IsA("Texture") then
			if tracker.originalDecalTransparency[child] == nil then
				tracker.originalDecalTransparency[child] = child.Transparency
			end
			child.Transparency = transparency
		end
	end

	if tracker.originalFaceTransparency == nil then
		local face = head:FindFirstChild("face")
		if face and (face:IsA("Decal") or face:IsA("Texture")) then
			tracker.originalFaceTransparency = face.Transparency
		end
	end

	local face = head:FindFirstChild("face")
	if face and (face:IsA("Decal") or face:IsA("Texture")) then
		face.Transparency = transparency
	end
end

local function restoreFaceTransparency(head, tracker)
	if not head then
		return
	end

	for child, transparency in pairs(tracker.originalDecalTransparency) do
		if child and child.Parent then
			pcall(function()
				child.Transparency = transparency
			end)
		end
	end

	local face = head:FindFirstChild("face")
	if face and (face:IsA("Decal") or face:IsA("Texture")) and tracker.originalFaceTransparency ~= nil then
		face.Transparency = tracker.originalFaceTransparency
	end
end

local function applyHeadEffectsToTracker(tracker, humanoid)
	local model = tracker.model
	local head = model and model:FindFirstChild("Head")
	if not head or not head:IsA("BasePart") then
		return
	end

	if tracker.originalHeadTransparency == nil then
		tracker.originalHeadTransparency = head.Transparency
	end
	if tracker.originalHeadCanCollide == nil then
		tracker.originalHeadCanCollide = head.CanCollide
	end
	if tracker.originalHeadMassless == nil then
		tracker.originalHeadMassless = head.Massless
	end
	if tracker.originalHeadSize == nil then
		tracker.originalHeadSize = head.Size
		local mesh = head:FindFirstChildOfClass("SpecialMesh")
		if mesh then
			tracker.originalHeadMeshScale = mesh.Scale
		end
		local headScale = humanoid and humanoid:FindFirstChild("HeadScale")
		if headScale and headScale:IsA("NumberValue") then
			tracker.originalHeadScaleValue = headScale.Value
		end
	end

	local shouldApply = false
	local sizeValue = 10
	local transparencyValue = 0

	if tracker.kind == "Player" then
		if tracker.player and getLocalTeamAllowed(tracker.player) then
			shouldApply = sizeEnabled
			sizeValue = playerHeadSize
			transparencyValue = playerHeadTransparency
		end
	else
		shouldApply = sizeEnabled
		sizeValue = npcHeadSize
		transparencyValue = npcHeadTransparency
	end

	local headScale = humanoid and humanoid:FindFirstChild("HeadScale")
	if headScale and headScale:IsA("NumberValue") then
		if shouldApply then
			headScale.Value = math.clamp(sizeValue / 10, 0.1, 10)
		elseif tracker.originalHeadScaleValue ~= nil then
			headScale.Value = tracker.originalHeadScaleValue
		end
	else
		local mesh = head:FindFirstChildOfClass("SpecialMesh")
		local scaleFactor = math.clamp(sizeValue / 10, 0.1, 10)
		if shouldApply then
			if mesh and tracker.originalHeadMeshScale then
				mesh.Scale = tracker.originalHeadMeshScale * scaleFactor
			else
				head.Size = tracker.originalHeadSize * scaleFactor
			end
			head.CanCollide = false
			head.Massless = true
		else
			head.Size = tracker.originalHeadSize
			if mesh and tracker.originalHeadMeshScale then
				mesh.Scale = tracker.originalHeadMeshScale
			end
			head.CanCollide = tracker.originalHeadCanCollide
			head.Massless = tracker.originalHeadMassless
		end
	end

	if shouldApply then
		head.Transparency = transparencyValue
		applyFaceTransparency(head, tracker, transparencyValue)
	else
		if tracker.originalHeadTransparency ~= nil then
			head.Transparency = tracker.originalHeadTransparency
		end
		restoreFaceTransparency(head, tracker)
	end
end

local function ensureTracker(model, kind, player)
	if trackers[model] then
		return trackers[model]
	end
	if not model or not model.Parent then
		return nil
	end

	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return nil
	end

	local tracker = createOverlayObjects(model, kind, player)
	trackers[model] = tracker

	humanoid.Died:Connect(function()
		if trackers[model] then
			trackers[model].highlight.Enabled = false
			trackers[model].holder.Enabled = false
		end
	end)

	return tracker
end

local function trackPlayerCharacter(player)
	if player == LocalPlayer then
		return
	end

	local function onCharacter(character)
		task.wait(0.15)
		if character and character.Parent then
			ensureTracker(character, "Player", player)
		end
	end

	player.CharacterAdded:Connect(onCharacter)

	if player.Character then
		task.spawn(onCharacter, player.Character)
	end
end

local function tryTrackNPCModel(model)
	local kind = getTargetKind(model)
	if kind ~= "NPC" then
		return
	end
	ensureTracker(model, "NPC", nil)
end

for _, player in ipairs(Players:GetPlayers()) do
	trackPlayerCharacter(player)
end

Players.PlayerAdded:Connect(trackPlayerCharacter)

for _, inst in ipairs(Workspace:GetDescendants()) do
	if inst:IsA("Model") then
		local kind = getTargetKind(inst)
		if kind == "NPC" then
			ensureTracker(inst, "NPC", nil)
		end
	end
end

Workspace.DescendantAdded:Connect(function(inst)
	if inst:IsA("Humanoid") and inst.Parent and inst.Parent:IsA("Model") then
		local model = inst.Parent
		task.delay(0.15, function()
			tryTrackNPCModel(model)
		end)
	end
end)

local function applyMovementToCharacter(character)
	local humanoid = character and character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		return
	end

	currentHumanoid = humanoid

	pcall(function()
		humanoid.UseJumpPower = true
	end)

	if originalHipHeight == nil then
		originalHipHeight = humanoid.HipHeight
	end

	humanoid.WalkSpeed = wsValue
	humanoid.JumpPower = jpValue

	if layingDown then
		humanoid.HipHeight = -2
	else
		humanoid.HipHeight = originalHipHeight or humanoid.HipHeight
	end
end

local function onCharacterAdded(character)
	task.wait(0.1)
	originalHipHeight = nil
	applyMovementToCharacter(character)
end

if LocalPlayer.Character then
	task.spawn(onCharacterAdded, LocalPlayer.Character)
end

LocalPlayer.CharacterAdded:Connect(onCharacterAdded)

local function setHeadValue(delta)
	if currentSizeMode == "Player" then
		playerHeadSize = clampHeadSize(playerHeadSize + delta)
	else
		npcHeadSize = clampHeadSize(npcHeadSize + delta)
	end
	refreshSizeUI()
end

local function setTransparencyValue(delta)
	if currentSizeMode == "Player" then
		playerHeadTransparency = clampTransparency(playerHeadTransparency + delta)
	else
		npcHeadTransparency = clampTransparency(npcHeadTransparency + delta)
	end
	refreshSizeUI()
