local function updateOverlayForTracker(tracker)
	local model = tracker.model
	if not model or not model.Parent then
		cleanupTracker(model)
		return
	end

	local humanoid = model:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		tracker.holder.Enabled = false
		tracker.highlight.Enabled = false
		return
	end

	if tracker.kind == "Player" then
		if not tracker.player or not getLocalTeamAllowed(tracker.player) then
			tracker.holder.Enabled = false
			tracker.highlight.Enabled = false
			setHumanoidDisplayHidden(tracker, humanoid, false)
			applyHeadEffectsToTracker(tracker, humanoid)
			return
		end
		if not xrayPlayerEnabled then
			tracker.holder.Enabled = false
			tracker.highlight.Enabled = false
		end
	else
		if not xrayNPCEnabled then
			tracker.holder.Enabled = false
			tracker.highlight.Enabled = false
		end
	end

	setHumanoidDisplayHidden(tracker, humanoid, hideHumanoidNames)
	applyHeadEffectsToTracker(tracker, humanoid)

	local adorneePart = getAdorneePart(model)
	if adorneePart then
		tracker.holder.Adornee = adorneePart
	end

	local alive = humanoid.Health > 0
	local nameText

	if tracker.kind == "Player" and tracker.player then
		nameText = tracker.player.DisplayName .. " (" .. tracker.player.Name .. ")"
	else
		nameText = model.Name
	end

	local healthText
	if alive then
		healthText = "Health: " .. math.floor(humanoid.Health) .. " / " .. math.floor(humanoid.MaxHealth)
	else
		healthText = "Dead"
	end

	tracker.holder.Enabled = (tracker.kind == "Player" and xrayPlayerEnabled and getLocalTeamAllowed(tracker.player)) or (tracker.kind == "NPC" and xrayNPCEnabled)
	tracker.highlight.Adornee = model
	tracker.highlight.Enabled = (tracker.kind == "Player" and xrayPlayerEnabled and getLocalTeamAllowed(tracker.player)) or (tracker.kind == "NPC" and xrayNPCEnabled)
	tracker.highlight.FillTransparency = alive and 0.75 or 0.9

	tracker.nameLabel.Text = nameText
	tracker.healthLabel.Text = healthText
	tracker.healthLabel.TextColor3 = alive and Color3.fromRGB(235, 235, 235) or Color3.fromRGB(255, 120, 120)
end

