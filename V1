local function clampHeadSize(value)
	return math.clamp(math.floor(value + 0.5), MIN_HEAD_SIZE, MAX_HEAD_SIZE)
end

local function clampTransparency(value)
	return math.clamp(math.floor((value * 10) + 0.5) / 10, MIN_HEAD_TRANSPARENCY, MAX_HEAD_TRANSPARENCY)
end

